{
  "id": "hyprpaper",
  "name": "Hyprpaper",
  "version": "1.0.0",
  "minNoctaliaVersion": "3.6.0",
  "author": "Noctalia",
  "license": "MIT",
  "description": "Wallpaper selector with local wallpapers and Wallhaven integration",
  "entryPoints": {
    "main":"Main.qml",    
    "barWidget": "BarWidget.qml",
    "panel": "Panel.qml",
    "settings": "Settings.qml"
  },
  "dependencies": {
    "plugins": []
  },
  "metadata": {
    "defaultSettings": {
      "directory": "~/Pictures/Wallpapers",
      "viewMode": "single",
      "sortOrder": "name",
      "setWallpaperOnAllMonitors": true,
      "enableMultiMonitorDirectories": false,
      "showHiddenFiles": false,
      "hideWallpaperFilenames": false,
      "useSolidColor": false,
      "solidColor": "#1a1a2e",
      "monitorDirectories": [],
      "favorites": [],
      "fillMode": "cover",
      "panelPosition": "bottom_center",
      "splash": true,
      "splash_offset": 2.0,
      "splash_opacity": 0.8,
      "ipc": true
    }
  }
}